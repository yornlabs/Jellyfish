# Jellyfish Backend - 环境变量示例
# 复制为 .env 后按需修改

# 应用
APP_NAME=Jellyfish API
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# 数据库（默认 SQLite 异步）
# DATABASE_URL=sqlite+aiosqlite:///./jellyfish.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jellyfish
# MySQL 示例（使用 aiomysql 驱动）:
# DATABASE_URL=mysql+aiomysql://user:pass@localhost:3306/jellyfish

# CORS 前端地址（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM（影视技能 /film/extract/* 用，不设则相关接口返回 503）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=gpt-4o-mini

# S3 / 对象存储（素材文件）
# 如使用 AWS S3，可按需填写：
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_REGION_NAME=ap-southeast-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=jellyfish-assets
# 可选统一前缀，方便按环境/项目隔离，如 jellyfish/dev
# S3_BASE_PATH=jellyfish/dev
# 若有 CDN/自定义域名，可配置成 https://cdn.example.com
# S3_PUBLIC_BASE_URL=
